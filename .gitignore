# ---------- 运行时 / 缓存 / 日志（不应入库）----------
*.pid
*.bak
nohup.out
msg/
log/
logs/
win-logs/
# vendor 依赖必须入库（clone 即运行模式）；勿因上面 log/ 等宽规则误忽略 vendor/psr/log 等包
!vendor/
__pycache__/
*.pyc
/venv/
/venv-linux/

# ---------- 前端调试残留 ----------
/assets/main/_*.js
/assets/main/_*.txt

# ---------- 部署生成物 ----------
.db-imported
*.log

# 本机整理脚本（非部署产物）
_stage.ps1
